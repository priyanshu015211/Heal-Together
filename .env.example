# OpenAI API key used by the AI Wellness Assistant (app/api/chat).
# Without this set, the chat API falls back to canned supportive responses
# so the app still runs end-to-end in development.
OPENAI_API_KEY=

# Reserved for future persistence layer (MongoDB / Firebase).
# The MVP currently uses an in-memory store (lib/store.js) so this is optional for now.
DATABASE_URL=
